# StudyRoomOps Environment Configuration
# Copy to .env and adjust values before starting

# MongoDB
MONGO_URI=mongodb://mongo1:27017,mongo2:27018,mongo3:27019/studyroomops?replicaSet=rs0
MONGO_DB_NAME=studyroomops

# JWT / Session
JWT_SECRET=change-me-to-a-secure-random-string-at-least-64-chars
JWT_IDLE_EXPIRY_MINUTES=30
JWT_ABSOLUTE_EXPIRY_HOURS=12

# CSRF
CSRF_SECRET=change-me-to-another-secure-random-string

# Encryption
FIELD_ENCRYPTION_KEY=change-me-32-byte-hex-key-for-aes256
FILE_ENCRYPTION_KEY=change-me-another-32-byte-hex-key

# Site Configuration
SITE_TIMEZONE=America/Los_Angeles
SITE_NAME=StudyRoomOps
API_PORT=3001
WEB_PORT=3000

# HTTPS
HTTPS_CERT_PATH=/certs/server.crt
HTTPS_KEY_PATH=/certs/server.key

# Vision Worker
VISION_WORKER_ENABLED=true
VISION_INTERNAL_KEY=change-me-vision-internal-key
FACE_CONFIDENCE_THRESHOLD=0.82
VISION_WORKER_URL=http://vision-worker:5000

# File Storage
# In Docker: /app/apps/api/uploads (container default in docker-compose)
# Outside Docker: leave unset to use <project>/apps/api/uploads automatically
# UPLOAD_DIR=/app/apps/api/uploads
# EXPORT_DIR=/tmp/studyroomops-exports

# Logging
LOG_LEVEL=info
NODE_ENV=production

# Rate Limiting
ACCOUNT_LOCKOUT_ATTEMPTS=5
ACCOUNT_LOCKOUT_WINDOW_MINUTES=15
ACCOUNT_LOCKOUT_DURATION_MINUTES=30

# Content Safety
SPAM_MAX_POSTS_PER_HOUR=5
SPAM_MAX_POSTS_PER_DAY=20

# Business Defaults
DEFAULT_BUSINESS_HOURS_START=07:00
DEFAULT_BUSINESS_HOURS_END=23:00
DEFAULT_MIN_RESERVATION_MINUTES=15
DEFAULT_MAX_RESERVATION_MINUTES=240
DEFAULT_NOSHOW_GRACE_MINUTES=15
DEFAULT_CHECKIN_REMINDER_MINUTES=10

# Wallet / Financial
DAILY_RISK_LIMIT_CENTS=20000
POINTS_PER_DOLLAR=1
POINTS_REDEMPTION_BLOCK=100
POINTS_REDEMPTION_VALUE_CENTS=100

# Retention
FACE_EVENT_RETENTION_DAYS=30
SESSION_RETENTION_DAYS=30
NOTIFICATION_RETENTION_DAYS=90
